OPENAI_API_KEY=

# Checkpoint defaults:
GOVEASE_EMBEDDING_PROVIDER=openai
GOVEASE_EMBEDDING_MODEL=text-embedding-3-small
GOVEASE_LLM_PROVIDER=openai-codex
GOVEASE_LLM_MODEL=gpt-5-mini

# Keep disabled for deterministic local tests; enable in integration environments.
GOVEASE_ENABLE_LLM_SEMANTIC=false

# Offline development fallback.
GOVEASE_LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2
GOVEASE_ALLOW_LOCAL_EMBEDDING_FALLBACK=false

# Shared data root inside data-pipeline.
GOVEASE_DATA_ROOT=../data

# FastAPI / deployment
GOVEASE_ENV=development
CHROMA_PATH=chroma_db
CHROMA_COLLECTION=procedures
CORS_ORIGINS=http://localhost:3000,https://gov-ease-ai.vercel.app
OPENAI_TIMEOUT_SECONDS=30
GOVEASE_AUTO_INITIALIZE_INDEX=true
