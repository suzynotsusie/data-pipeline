        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_2",
        "title": null,
        "content": "Trường hợp Trung tâm Phục vụ hành chính công tiếp nhận hồ sơ thì chuyển hồ sơ đến Văn phòng đăng ký đất đai, Chi nhánh Văn phòng đăng ký đất đai.",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_3",
        "title": null,
