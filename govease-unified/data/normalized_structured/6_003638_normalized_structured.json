  "process": {
    "steps": [
      {
        "step_id": "step_1",
        "title": null,
        "content": "1. + Trong thời hạn 05 ngày kể từ ngày hết thời hạn phải bàn giao nhà ở theo quyết",
        "actor": "user",
        "channel_hint": null,
        "time_hint": "05 ngày"
      },
      {
        "step_id": "step_2",
        "title": null,
        "content": "định thu hồi nhà ở mà người đang sử dụng nhà ở không bàn giao nhà ở thì đơn vị",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_3",
        "title": null,
        "content": "quản lý vận hành nhà ở phải có văn bản báo cáo cơ quan quản lý nhà ở đề nghị",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_4",
        "title": null,
        "content": "cưỡng chế thu hồi nhà ở;",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_5",
        "title": null,
        "content": "2. + Trong thời hạn 05 ngày kể từ ngày nhận được báo cáo của đơn vị quản lý vận",
        "actor": "user",
        "channel_hint": null,
        "time_hint": "05 ngày"
      },
      {
        "step_id": "step_6",
        "title": null,
        "content": "hành nhà ở, cơ quan quản lý nhà ở phải kiểm tra và có tờ trình kèm theo dự thảo",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_7",
        "title": null,
        "content": "quyết định cưỡng chế thu hồi nhà ở gửi cơ quan đại diện chủ sở hữu nhà ở xem",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_8",
        "title": null,
        "content": "xét, ban hành quyết định cưỡng chế thu hồi nhà ở;",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_9",
        "title": null,
        "content": "3. + Trong thời hạn 10 ngày kể từ ngày nhận được tờ trình của cơ quan quản lý nhà",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": "10 ngày"
      },
      {
        "step_id": "step_10",
        "title": null,
        "content": "ở, cơ quan đại diện chủ sở hữu nhà ở có trách nhiệm xem xét, ban hành quyết định",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_11",
        "title": null,
        "content": "cưỡng chế thu hồi nhà ở và gửi quyết định này cho cơ quan quản lý nhà ở, đơn vị",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_12",
        "title": null,
        "content": "quản lý vận hành nhà ở và người đang trực tiếp sử dụng nhà ở biết để thực hiện.",
        "actor": "user",
        "channel_hint": "trực tiếp",
        "time_hint": null
      },
      {
        "step_id": "step_13",
        "title": null,
        "content": "4. + Trường hợp cơ quan trung ương ban hành quyết định cưỡng chế thu hồi nhà ở",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_14",
        "title": null,
        "content": "thì cơ quan này phải có văn bản kèm theo quyết định cưỡng chế thu hồi nhà ở đề",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_15",
        "title": null,
        "content": "nghị Ủy ban nhân dân cấp tỉnh nơi có nhà ở phối hợp tổ chức cưỡng chế thu hồi;",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_16",
        "title": null,
        "content": "5. + Trường hợp nhà ở không thuộc diện phải tổ chức cưỡng chế thu hồi thì cơ quan",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_17",
        "title": null,
        "content": "đại diện chủ sở hữu phải có văn bản thông báo cho cơ quan quản lý nhà ở và đơn",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_18",
        "title": null,
        "content": "vị quản lý vận hành nhà ở biết để tiếp tục thực hiện quản lý theo quy định.",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_19",
        "title": null,
        "content": "Đối với nhà ở đang do Bộ Quốc phòng, Bộ Công an quản lý thì cơ quan có chức",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_20",
        "title": null,
        "content": "năng quản lý nhà ở của Bộ Quốc phòng, Bộ Công an được quyền ban hành quyết",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_21",
        "title": null,
        "content": "định cưỡng chế thu hồi nhà ở nếu được giao thực hiện;",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_22",
        "title": null,
        "content": "6. + Trên cơ sở quyết định cưỡng chế thu hồi nhà ở, Ủy ban nhân dân cấp tỉnh nơi",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_23",
        "title": null,
        "content": "có nhà ở trực tiếp hoặc giao cho Ủy ban nhân dân cấp huyện nơi có nhà ở chủ trì,",
        "actor": "user",
        "channel_hint": "trực tiếp",
        "time_hint": null
      },
      {
        "step_id": "step_24",
        "title": null,
        "content": "phối hợp với cơ quan quản lý nhà ở cấp tỉnh, cơ quan công an cấp huyện và Ủy",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_25",
        "title": null,
        "content": "ban nhân dân cấp xã nơi có nhà ở tổ chức cưỡng chế thu hồi và bàn giao lại nhà ở",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_26",
        "title": null,
        "content": "cho đơn vị quản lý vận hành quản lý nhà ở theo quy định. Việc bàn giao nhà ở",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_27",
        "title": null,
        "content": "phải được lập thành biên bản có xác nhận của các cơ quan tham gia cưỡng chế thu",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_28",
        "title": null,
        "content": "hồi.",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      }
