      {
        "step_id": "step_18",
        "title": null,
        "content": "Quốc phòng, Bộ Công an lập tờ trình gửi lấy ý kiến của cơ quan tài chính về dự",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_19",
        "title": null,
