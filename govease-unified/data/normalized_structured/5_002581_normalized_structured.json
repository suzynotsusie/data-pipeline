        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_7",
        "title": null,
        "content": "trước khi báo cáo Bộ Xây dựng xem xét, quyết định. Trên cơ sở ý kiến của cơ quan",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_8",
        "title": null,
        "content": "tài chính, cơ quan quản lý nhà ở trực thuộc hoàn thiện lại tờ trình và báo cáo Bộ",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_9",
        "title": null,
        "content": "Xây dựng xem xét, chấp thuận. Sau khi có ý kiến chấp thuận của Bộ Xây dựng, cơ",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_10",
        "title": null,
        "content": "quan quản lý nhà ở trực thuộc Bộ Xây dựng có trách nhiệm ký hợp đồng thuê với",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_11",
        "title": null,
        "content": "chủ sở hữu nhà ở thương mại; việc cấp kinh phí để thanh toán tiền thuê nhà được",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_12",
        "title": null,
        "content": "thực hiện theo ý kiến chấp thuận của Bộ Xây dựng và pháp luật về ngân sách. Sau",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_13",
        "title": null,
        "content": "khi ký hợp đồng thuê nhà ở thương mại, cơ quan quản lý nhà ở tiếp nhận nhà ở, ký",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_14",
        "title": null,
        "content": "hợp đồng cho thuê nhà ở công vụ và thu tiền thuê nhà ở công vụ theo quy định của",
