      },
      {
        "step_id": "step_2",
        "title": null,
        "content": "+ Việc thuê nhà ở thương mại để làm nhà ở công vụ phục vụ cho các đối",
        "actor": "user",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_3",
        "title": null,
        "content": "tượng thuộc cơ quan trung ương được quy định như sau: Cơ quan quản lý nhà ở",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_4",
        "title": null,
        "content": "trực thuộc Bộ Xây dựng có trách nhiệm lập tờ trình gửi lấy ý kiến của cơ quan có",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_5",
        "title": null,
        "content": "liên quan, trong đó lấy ý kiến của cơ quan tài chính về dự toán kinh phí thuê nhà ở",
        "actor": "authority",
        "channel_hint": null,
        "time_hint": null
      },
      {
        "step_id": "step_6",
        "title": null,
        "content": "trong nguồn ngân sách chi thường xuyên theo quy định của pháp luật về ngân sách",
